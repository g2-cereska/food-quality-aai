# Datasets — never commit raw images
data/
!data/.gitkeep

# Trained model weights — too large to track sensibly in git history,
# regenerate via: python -m src.train --architecture <name>
outputs/**/*.pth
outputs/**/*.joblib
outputs/**/checkpoints/

# Result artifacts (metrics.json, classification_report.csv, confusion
# matrix and training curve images) ARE committed — they're small,
# human-readable, and are the actual evidence of what was run.

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
*.egg-info/
.pytest_cache/

# OS / editor
.DS_Store
.vscode/
*.swp

# Jupyter
.ipynb_checkpoints/

# Environment secrets
.env